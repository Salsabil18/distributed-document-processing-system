import cv2

# Read image
image = cv2.imread("document.jpg")

# Convert to grayscale
gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

# Threshold
_, thresh = cv2.threshold(
    gray,
    0,
    255,
    cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU
)

# Create horizontal kernel
kernel = cv2.getStructuringElement(
    cv2.MORPH_RECT,
    (25,5)
)

# Dilate image
dilated = cv2.dilate(
    thresh,
    kernel,
    iterations=1
)

# Find contours
contours, _ = cv2.findContours(
    dilated,
    cv2.RETR_EXTERNAL,
    cv2.CHAIN_APPROX_SIMPLE
)

output = image.copy()

for contour in contours:

    x,y,w,h = cv2.boundingRect(contour)

    if w>60 and h>20:

        cv2.rectangle(
            output,
            (x,y),
            (x+w,y+h),
            (0,255,0),
            2
        )

cv2.namedWindow("Dilated", cv2.WINDOW_NORMAL)
cv2.imshow("Dilated",dilated)
cv2.resizeWindow("Dilated", 1000, 800)


cv2.namedWindow("Detected Blocks", cv2.WINDOW_NORMAL)
cv2.imshow("Detected Blocks",output)
cv2.resizeWindow("Detected Blocks", 1000, 800)

cv2.waitKey(0)
cv2.destroyAllWindows()

